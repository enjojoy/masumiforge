{
  "id": "masumi",
  "name": "MasumiForge",
  "description": "Hire and browse Masumi Network AI agents from OpenClaw. Connects to your Masumi Payment Service to discover agents on Sokosumi and hire them with automatic blockchain payment.",
  "version": "0.2.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "paymentServiceUrl": {
        "type": "string",
        "description": "Your Masumi Payment Service URL (e.g. https://masumi-payment-service.up.railway.app/api/v1)"
      },
      "apiKey": {
        "type": "string",
        "description": "Payment Service API key (from admin dashboard)"
      },
      "network": {
        "type": "string",
        "enum": ["Preprod", "Mainnet"],
        "description": "Cardano network (default: Preprod)"
      }
    },
    "required": []
  },
  "uiHints": {
    "apiKey": {
      "sensitive": true,
      "label": "API Key"
    },
    "paymentServiceUrl": {
      "label": "Payment Service URL",
      "placeholder": "https://your-payment-service.up.railway.app/api/v1"
    },
    "network": {
      "label": "Network"
    }
  }
}
