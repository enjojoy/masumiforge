{
  "id": "masumi",
  "name": "MasumiForge",
  "description": "Forge, list, and hire Masumi Network agents from OpenClaw",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "paymentServiceUrl": {
        "type": "string",
        "description": "Masumi Payment Service URL (e.g. http://localhost:3001/api/v1)"
      },
      "apiKey": {
        "type": "string",
        "description": "Masumi Payment Service API key"
      },
      "registryUrl": {
        "type": "string",
        "description": "Masumi Registry Service URL (default: http://registry.masumi.network)"
      },
      "network": {
        "type": "string",
        "enum": ["Preprod", "Mainnet"],
        "description": "Cardano network to use"
      }
    }
  },
  "uiHints": {
    "apiKey": {
      "sensitive": true,
      "label": "API Key"
    },
    "paymentServiceUrl": {
      "label": "Payment Service URL",
      "placeholder": "http://localhost:3001/api/v1"
    },
    "registryUrl": {
      "label": "Registry URL",
      "placeholder": "http://registry.masumi.network"
    },
    "network": {
      "label": "Network"
    }
  }
}
